# Sunyata AI Microservice - Environment Variables

# Anthropic API Key (kept for fallback)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# LiteLLM Proxy (multi-provider gateway on VM102)
LITELLM_BASE_URL=http://192.168.100.13:4000
LITELLM_API_KEY=your-litellm-master-key-here

# PostgreSQL connection
DATABASE_URL=postgresql://sunyata_app:your_password@localhost:5432/sunyata_platform

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Internal API key (PHP -> FastAPI authentication)
INTERNAL_API_KEY=generate-a-secure-random-key-here

# Service settings
HOST=127.0.0.1
PORT=8000
DEBUG=false
