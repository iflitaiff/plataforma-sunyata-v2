# Sunyata AI Microservice - Environment Variables

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# PostgreSQL connection
DATABASE_URL=postgresql://sunyata_app:your_password@localhost:5432/sunyata_platform

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Internal API key (PHP -> FastAPI authentication)
INTERNAL_API_KEY=generate-a-secure-random-key-here

# Service settings
HOST=127.0.0.1
PORT=8000
DEBUG=false
