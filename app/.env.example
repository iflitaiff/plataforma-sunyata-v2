# Plataforma Sunyata V2 - Environment Variables

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sunyata_platform
DB_USER=sunyata_app
DB_PASSWORD=your_password_here

# Redis (sessions + cache)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PREFIX=sunyata_

# FastAPI Microservice (Phase 3)
FASTAPI_BASE_URL=http://127.0.0.1:8000
FASTAPI_ENABLED=false  # Set to 'true' to use FastAPI instead of direct Anthropic API

# LiteLLM (optional, for direct calls)
LITELLM_BASE_URL=http://192.168.100.13:4000
LITELLM_API_KEY=sk-sunyata-your-key-here

# Application
APP_ENV=development  # development|staging|production
APP_DEBUG=true
APP_URL=http://localhost

# Claude API (for direct calls when FASTAPI_ENABLED=false)
# IMPORTANT: Keep this in app/config/secrets.php, NOT in .env
# CLAUDE_API_KEY=sk-ant-your-key-here

# Security
SESSION_LIFETIME=7200  # 2 hours in seconds
CSRF_TOKEN_LIFETIME=3600  # 1 hour

# File Uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,docx,txt

# Logging
LOG_LEVEL=info  # debug|info|warning|error
LOG_CHANNEL=file  # file|syslog|stderr
