/**
 * Plataforma Sunyata - Secrets Configuration
 *
 * IMPORTANT: Copy this file to secrets.php and configure with your actual credentials
 * NEVER commit secrets.php to version control
 *
 * @package Sunyata
 */

// Database Configuration (PostgreSQL)
define('DB_HOST', 'localhost');
define('DB_PORT', '5432');
define('DB_NAME', 'sunyata_platform');
define('DB_USER', 'sunyata_app');
define('DB_PASS', 'your_db_password');

// Google OAuth Configuration (optional — email/password auth works without this)
// Get credentials from: https://console.cloud.google.com/apis/credentials
define('GOOGLE_CLIENT_ID', 'your-client-id.apps.googleusercontent.com');
define('GOOGLE_CLIENT_SECRET', 'your-client-secret');

// Session Security
define('SESSION_SECRET', 'generate-random-string-here'); // Use: bin2hex(random_bytes(32))

// Claude API Configuration
// Get your API key from: https://console.anthropic.com/
define('CLAUDE_API_KEY', 'sk-ant-api03-your-key-here');

// DPO (Data Protection Officer) contact
define('DPO_EMAIL', 'flitaiff@gmail.com');

// Optional: Environment
define('ENVIRONMENT', 'development'); // development, staging, production
