                                                        <?php endif; ?>

                                                        <!-- Metadata -->
                                                        <div class="row">
                                                            <div class="col-md-3">
                                                                <strong>Modelo:</strong> <?= sanitize_output($item['claude_model'] ?? 'N/A') ?>
                                                            </div>
                                                            <div class="col-md-3">
                                                                <strong>Tempo Resposta:</strong> <?= $item['response_time_ms'] ?? 'N/A' ?>ms
                                                            </div>
                                                            <div class="col-md-3">
                                                                <strong>IP:</strong> <?= sanitize_output($item['ip_address'] ?? 'N/A') ?>
                                                            </div>
                                                            <div class="col-md-3">
                                                                <strong>User Agent:</strong>
                                                                <small><?= sanitize_output(substr($item['user_agent'] ?? 'N/A', 0, 50)) ?>...</small>
